# ============================================
# Nexus Prediction Market - Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# ============================================
# OpenAI / LLM Configuration
# ============================================
# OpenAI API Key for AI predictions and analysis
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Custom OpenAI base URL (for proxy or alternative providers)
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================
# Database Configuration
# ============================================
# MySQL database connection string
# Format: mysql://username:password@host:port/database
DATABASE_URL=mysql://root:password@localhost:3306/nexus_prediction_market

# ============================================
# OAuth Configuration
# ============================================
# OAuth server URL for user authentication
OAUTH_SERVER_URL=https://oauth.example.com

# OAuth client credentials
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret

# ============================================
# AWS S3 Configuration (Optional)
# ============================================
# AWS access key for S3 file uploads
AWS_ACCESS_KEY_ID=your-access-key

# AWS secret access key
AWS_SECRET_ACCESS_KEY=your-secret-key

# AWS S3 region
AWS_REGION=us-east-2

# AWS S3 bucket name
AWS_S3_BUCKET=nexus-prediction-market

# ============================================
# Application Configuration
# ============================================
# Node environment: development, production, test
NODE_ENV=production

# Server port
PORT=3000

# Application domain
APP_DOMAIN=localhost:3000

# ============================================
# Smart Contract Configuration
# ============================================
# RPC endpoint for blockchain interaction
RPC_ENDPOINT=https://polygon-rpc.com

# Contract addresses
BINARY_MARKET_ADDRESS=0x...
COPY_TRADING_VAULT_ADDRESS=0x...

# ============================================
# Feature Flags
# ============================================
# Enable AI predictions
ENABLE_AI_PREDICTIONS=true

# Enable copy trading
ENABLE_COPY_TRADING=true

# Enable World Cup markets
ENABLE_WORLD_CUP_MARKETS=true

# ============================================
# Logging Configuration
# ============================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# ============================================
# Rate Limiting
# ============================================
# API rate limit (requests per minute)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# Session Configuration
# ============================================
# Session secret for cookie signing
SESSION_SECRET=your-secret-key-here

# Session cookie max age (in milliseconds)
SESSION_MAX_AGE=2592000000

# ============================================
# CORS Configuration
# ============================================
# Allowed origins for CORS
CORS_ORIGIN=http://localhost:3000,https://example.com

# ============================================
# Email Configuration (Optional)
# ============================================
# SMTP server for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Email from address
EMAIL_FROM=noreply@nexus.example.com
